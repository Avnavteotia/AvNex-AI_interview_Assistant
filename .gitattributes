# Auto detect text files and perform LF normalization
* text=auto

# Python
*.py text eol=lf

# JavaScript/TypeScript
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf

# Web
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf

# Config
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.ini text eol=lf

# Markdown
*.md text eol=lf
